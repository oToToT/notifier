{
  "server": {
    "bind": "127.0.0.1:8080",
    "public_base_url": "https://notify.example.com"
  },
  "storage": {
    "sqlite_path": "notifier.db"
  },
  "delivery": {
    "workers": 4,
    "max_attempts": 8
  },
  "srcs": {
    "nitter-example": {
      "plugin": "nitter",
      "spec": {
        "instance_url": "https://nitter.net",
        "tweet_url_base": "https://fxtwitter.com",
        "first_fetch": "mark_seen",
        "poll_interval_seconds": 300,
        "request_timeout_seconds": 20,
        "retry_initial_seconds": 30,
        "retry_max_seconds": 1800
      }
    },
    "twitch-example": {
      "plugin": "twitch",
      "spec": {
        "webhook_path": "/hooks/twitch-example",
        "client_id": "replace-me",
        "client_secret": "replace-me",
        "webhook_secret": "replace-with-10-to-100-characters"
      }
    }
  },
  "dsts": {
    "discord-main": {
      "plugin": "discord",
      "spec": {
        "bot_token": "replace-me"
      }
    }
  },
  "routes": [
    {
      "id": "nitter-example-to-discord",
      "src": {
        "id": "nitter-example",
        "input": {
          "users": ["example", "another_example"]
        }
      },
      "dst": {
        "id": "discord-main",
        "input": {
          "channel_id": "1234567890"
        }
      },
      "message": "{{ user.username }} tweeted: {{ tweet.title }}\n{{ tweet.url }}"
    },
    {
      "id": "twitch-example-to-discord",
      "src": {
        "id": "twitch-example",
        "input": {
          "broadcasters": ["example", "another_example"]
        }
      },
      "dst": {
        "id": "discord-main",
        "input": {
          "channel_id": "1234567890"
        }
      },
      "message": "{{ broadcaster.name }} is live: {{ stream.title }}\n{{ stream.url }}"
    }
  ]
}
